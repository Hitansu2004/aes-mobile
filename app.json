{
  "expo": {
    "name": "Arial Engineering",
    "slug": "aes-mobile",
    "scheme": "aes",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arialengineering.aes",
      "associatedDomains": ["applinks:portal.arialengineering.com"]
    },
    "android": {
      "package": "com.arialengineering.aes",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#0B1A2C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "portal.arialengineering.com"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-image",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#C9A84C"
        }
      ],
      "expo-image-picker",
      "expo-location",
      "expo-navigation-bar"
    ],
    "extra": {
      "router": {}
    }
  }
}
