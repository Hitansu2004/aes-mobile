{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.x:8080/api/v1",
        "EXPO_PUBLIC_WS_URL": "ws://192.168.1.x:8080/ws/websocket"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging.arialengineering.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://staging.arialengineering.com/ws/websocket"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.arialengineering.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://api.arialengineering.com/ws/websocket"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-key.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "TODO-your-apple-id@example.com",
        "ascAppId": "TODO-app-store-connect-app-id",
        "appleTeamId": "TODO-apple-team-id"
      }
    }
  }
}
